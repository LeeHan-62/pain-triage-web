<view class="page">
  <view class="card">
    <view class="section-title">OpenEMR 档案联动模拟</view>
    <view class="subtitle">当前原型将问诊记录保存在小程序本地缓存。正式部署时可在提交结果后调用后端接口，写入 OpenEMR 患者健康档案。</view>
  </view>

  <view wx:if="{{records.length}}">
    <view class="record card" wx:for="{{records}}" wx:key="id">
      <view class="record-head">
        <view>
          <view class="patient">{{item.patientName}}</view>
          <view class="time">{{item.createdAt}}</view>
        </view>
        <view class="level" style="color: {{item.risk.color}};">{{item.risk.level}}</view>
      </view>
      <view class="summary">{{item.summary}}</view>
      <view class="tags">
        <text class="tag">{{item.part}}</text>
        <text class="tag">{{item.nature}}</text>
        <text class="tag">{{item.department}}</text>
      </view>
    </view>
    <button class="ghost-btn" bindtap="clearRecords">清空本地模拟档案</button>
  </view>

  <view class="card empty" wx:else>
    <view class="section-title">暂无档案记录</view>
    <view class="subtitle">完成问诊后，系统会自动保存疼痛分类结果和风险等级。</view>
  </view>
</view>
