.hero {
  background: linear-gradient(135deg, #1f6feb, #60a5fa);
  color: #ffffff;
}

.hero .subtitle {
  color: rgba(255, 255, 255, 0.86);
}

.hero .primary-btn {
  background: #ffffff;
  color: #1f6feb;
}

.flow-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  color: #334155;
  font-size: 28rpx;
}

.flow-item:last-child {
  border-bottom: none;
}

.risk-row {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  padding: 12rpx 0;
  color: #334155;
}

.risk-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 14rpx;
}

.red {
  background: #d93025;
}

.orange {
  background: #f97316;
}

.blue {
  background: #2563eb;
}

.green {
  background: #16a34a;
}
