.risk-card {
  border-left: 12rpx solid #1f6feb;
}

.risk-level {
  font-size: 44rpx;
  font-weight: 800;
}

.risk-action {
  margin-top: 16rpx;
  color: #334155;
  font-size: 30rpx;
  line-height: 1.6;
}

.result-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.result-item {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
}

.value {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #17233d;
}

.summary {
  color: #334155;
  font-size: 30rpx;
  line-height: 1.7;
}
