page {
  min-height: 100vh;
  background: #f4f7fb;
  color: #17233d;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(31, 111, 235, 0.08);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.subtitle {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.primary-btn {
  background: #1f6feb;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  margin-top: 24rpx;
}

.ghost-btn {
  background: #eef5ff;
  color: #1f6feb;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #1f6feb;
  font-size: 24rpx;
  margin: 0 12rpx 12rpx 0;
}

.muted {
  color: #64748b;
}
